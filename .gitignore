# =============================================================================
# memex .gitignore
#
# This repo is PUBLIC. Personal data must NEVER be committed.
# Anything resembling a data file, secret, or local-only artifact is blocked
# below. When in doubt, add the path explicitly here before staging.
# =============================================================================

# -----------------------------------------------------------------------------
# Data — the hard boundary
# -----------------------------------------------------------------------------
# Anclado a la raíz (/) — `data/` sin ancla también ignoraba frontend/src/data (el facade del
# dashboard) y frontend/src/components/features/data. El ./data de la raíz (sesiones, etc.) sigue.
/data/
datasets/
exports/
dumps/
raw/
processed/

# Spikes / experimentos throwaway (scripts de diseño, outputs de LLM, scratch).
# No es código de producción ni se versiona; vive acá para correr con el venv.
experiments/
*.csv
*.tsv
*.parquet
*.feather
*.arrow
*.orc
*.avro
*.jsonl
*.ndjson
*.db
*.db-journal
*.sqlite
*.sqlite3
*.duckdb
*.h5
*.hdf5
*.pkl
*.pickle
*.npz
*.npy

# Notebook outputs (often contain rendered data)
*.ipynb_checkpoints/
# Keep the .ipynb files themselves but never their outputs — strip with nbstripout

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.cer
*.p12
*.pfx
secrets/
credentials/
.doppler/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.tox/
.hypothesis/
pip-wheel-metadata/
*.egg-info/
build/
dist/

# -----------------------------------------------------------------------------
# Node / JS
# -----------------------------------------------------------------------------
node_modules/
.next/
.nuxt/
.svelte-kit/
out/
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Rust / Go
# -----------------------------------------------------------------------------
target/
Cargo.lock.bak
bin/
pkg/

# -----------------------------------------------------------------------------
# Tooling
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
.terragrunt-cache/

# -----------------------------------------------------------------------------
# IDE / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
/logs/

# -----------------------------------------------------------------------------
# Claude Code / agent: caches, artefactos de sesión y git worktrees (.claude/worktrees/).
# Se ignora todo `.claude/` (no es código del proyecto; un `git add -A` no debe agarrarlo).
# -----------------------------------------------------------------------------
.claude/

# Diagramas de arquitectura — artefactos locales, no se versionan.
# Las fuentes (.dot/.mmd) y los renders (.png/.svg) son regenerables y
# pueden contener referencias personales temporales mientras se trabaja.
*-architecture.*

# -----------------------------------------------------------------------------
# Telethon session files (Telegram ingestor)
# -----------------------------------------------------------------------------
# `.session` y `.session-journal` son SQLite con credenciales de la cuenta
# Telegram — committearlos = leak total de la cuenta.
*.session
*.session-journal
