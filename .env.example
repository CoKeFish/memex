MEMEX_DATABASE_URL=postgresql+psycopg://memex:memex@localhost:5454/memex
MEMEX_AUTH_ENFORCED=false
MEMEX_API_TOKEN=
MEMEX_LOG_LEVEL=INFO

# ----- Ingestors -----------------------------------------------------------
# The ingestor CLIs (e.g. memex.ingestors.imap.cli) read these to talk to memex.
MEMEX_BASE_URL=http://localhost:8787

# IMAP credentials are referenced by env var name from sources.config — the
# actual values live here (or in real env vars at deploy time), never in the DB.
# Two supported auth modes:
#
# A) Basic auth + Gmail App Password
#    Generate at https://myaccount.google.com/apppasswords (requires 2FA).
#    Set sources.config.auth = "basic".
# MEMEX_IMAP_GMAIL_USER=you@gmail.com
# MEMEX_IMAP_GMAIL_PASS=xxxx xxxx xxxx xxxx
#
# B) OAuth2 (XOAUTH2 SASL) — no password ever stored.
#    1. Crear OAuth Client tipo "Desktop application" en Google Cloud Console
#       (https://console.cloud.google.com/apis/credentials). Habilitar Gmail API.
#    2. Bajar client_secret.json y guardarlo en disco (path absoluto debajo).
#    3. Correr: uv run python -m memex.ingestors.imap.cli authorize --source-id N
#       Se abre navegador, das consentimiento, los tokens se guardan en el path
#       de TOKEN_JSON debajo.
#    4. Set sources.config.auth = "oauth2" y los _env apuntando a estos paths.
# Guardá las credenciales DENTRO del repo, en secrets/ (está en .gitignore; el repo es PÚBLICO).
# Nunca en el home ni fuera del repo.
# MEMEX_IMAP_GMAIL_USER=you@gmail.com
# MEMEX_IMAP_GMAIL_CLIENT_SECRET_JSON=<repo>\secrets\google_client_secret.json
# MEMEX_IMAP_GMAIL_TOKEN_JSON=<repo>\secrets\gmail_token.json

# ----- Telegram ingestor (server-side polling) -----------------------------
# Get api_id / api_hash from https://my.telegram.org/apps (one-time).
# `phone` debe estar en formato E.164, ej. "+34xxxxxxxxx".
# El primer run de `memex-telegram auth --source-id N` dispara SMS y guarda
# el `.session` file en MEMEX_TG_SESSION_PATH. Ese file es un secreto crítico
# (acceso TOTAL a tu cuenta Telegram) — está en .gitignore por defecto.
# MEMEX_TG_API_ID=12345678
# MEMEX_TG_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MEMEX_TG_PHONE=+34xxxxxxxxx
# MEMEX_TG_SESSION_PATH=<repo>\data\telegram-sessions

# ----- LLM (DeepSeek) -------------------------------------------------------
# Capa LLM provider-agnóstica (memex.llm). A diferencia del resto, la API key NO
# usa el prefijo MEMEX_: DEEPSEEK_API_KEY es el nombre canónico de DeepSeek y se
# lee directo de os.environ (vía LLMConfig.from_env), no del Settings global.
# En prod se inyecta por Doppler (config "shared"); para dev local, descomentá:
# DEEPSEEK_API_KEY=sk-...

# ----- Almacenamiento de imágenes (MinIO / S3) -----------------------------
# memex.storage guarda los blobs de imágenes adjuntas; en la DB va solo la
# referencia (object-key). El endpoint/bucket llevan prefijo MEMEX_; las
# credenciales NO (MINIO_ACCESS_KEY/SECRET_KEY = root user/password de MinIO,
# nombres canónicos, inyectados por Doppler). Con `docker compose up -d minio`:
MEMEX_MINIO_ENDPOINT=http://localhost:9000
MEMEX_MINIO_BUCKET=memex-media
# MEMEX_MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=memexminio
MINIO_SECRET_KEY=memexminio-dev-secret

# ----- OCR (proveedor de visión) -------------------------------------------
# memex.ocr OCR-ea las imágenes con un LLM de visión vía API OpenAI-compatible.
# La key es canónica (sin prefijo MEMEX_, Doppler); base_url + model indican el
# PROVEEDOR y el MODELO (override por corrida con `memex-ocr run --model ...`).
# OCR_API_KEY=sk-...
# MEMEX_OCR_BASE_URL=https://api.openai.com/v1
# MEMEX_OCR_MODEL=gpt-4o-mini
#
# OCR de PDFs (memex.ocr.pdf, vía pymupdf): capa de texto gratis + visión de imágenes/páginas.
# Topes para acotar el fan-out de costo (cada imagen/página = 1 llamada de visión). Defaults
# conservadores; descomentá para ajustar.
# MEMEX_OCR_PDF_MAX_IMAGES=5      # máx. imágenes embebidas OCR-eadas por PDF (más → se omiten)
# MEMEX_OCR_PDF_MAX_PAGES=5       # máx. páginas rasterizadas en PDFs escaneados (sin capa de texto)
# MEMEX_OCR_PDF_MIN_IMAGE_PX=200  # ignora imágenes < N px (logos/íconos/tracking pixels)
# MEMEX_OCR_PDF_TEXT_MIN_CHARS=32 # umbral de texto para tratar el PDF como digital vs escaneado
#
# OCR de adjuntos ZIP (memex.ocr.zip, vía pyzipper): descomprime y rutea cada entrada (imagen→visión,
# PDF→pipeline de PDF, texto→directo). Topes anti-zip-bomb (los de tamaño en MiB). SIN recursión.
# MEMEX_OCR_ZIP_MAX_ENTRIES=20    # máx. entradas procesadas por ZIP
# MEMEX_OCR_ZIP_MAX_TOTAL_MB=50   # máx. total descomprimido por ZIP (MiB)
# MEMEX_OCR_ZIP_MAX_ENTRY_MB=15   # máx. por entrada (MiB)
#
# Pool de contraseñas para adjuntos ENCRIPTADOS (ZIP/PDF) — p. ej. tus nº de documento de identidad.
# SECRETO: inyectado por Doppler, separado por comas, redactado en logs (SecretStr), nunca en la DB.
# Vacío → los adjuntos encriptados quedan en `error`. Solo aplica a adjuntos de correo (IMAP).
# MEMEX_ATTACHMENT_PASSWORDS=12345678X,ABC123456
