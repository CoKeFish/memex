digraph ingestors {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=11, splines=spline, nodesep=0.4, ranksep=0.9, bgcolor="white"];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", penwidth=1.2];
  edge  [fontname="Helvetica", fontsize=9, color="#555555"];

  // ---------------- memex.core (contratos) ----------------
  subgraph cluster_core {
    label="memex.core  (contratos, sin I/O)";
    style="rounded,filled"; fillcolor="#f6f1ff"; color="#7a4ddb"; fontcolor="#4a2da0";
    SRC  [label="Source (Protocol)\nfetch / advance_checkpoint", fillcolor="#ece1ff", color="#7a4ddb", style="rounded,filled,dashed"];
    SNK  [label="MemexSink (Protocol)\nget/put_checkpoint\npost_ingest_batch\nget_sources_by_type", fillcolor="#ece1ff", color="#7a4ddb", style="rounded,filled,dashed"];
    REC  [label="SourceRecord", fillcolor="#ffffff", color="#7a4ddb"];
  }

  // ---------------- memex.ingestors (genérico + IMAP) ----------------
  subgraph cluster_ing {
    label="memex.ingestors   (aislado — ADR-001)";
    style="rounded,filled"; fillcolor="#eef7ff"; color="#2d6cdf"; fontcolor="#1d4f9e";

    RUNNER [label="runner.run_ingestor\nchunk + checkpoint + retry", fillcolor="#ffffff", color="#2d6cdf"];
    HTTPC  [label="http_client.MemexClient\nimplementa MemexSink\nensure_source\nconfigurable ingest_path", fillcolor="#ffffff", color="#2d6cdf"];

    subgraph cluster_imap {
      label="imap/   (Source concreto)";
      style="rounded,filled"; fillcolor="#dceeff"; color="#2d6cdf";
      IMAP_CLI    [label="cli.py\n(deploy en VPS)", fillcolor="#ffffff", color="#2d6cdf"];
      IMAP_SRC    [label="ImapSource\nImapConfig\nImapClient", fillcolor="#ffffff", color="#2d6cdf"];
      IMAP_OAUTH  [label="oauth/\n google · microsoft", fillcolor="#ffffff", color="#2d6cdf"];
    }
  }

  // ---------------- memex_local (NUEVO — PC del usuario) ----------------
  subgraph cluster_local {
    label="memex_local   (cliente local, PC del usuario)";
    style="rounded,filled"; fillcolor="#fff4e5"; color="#c97a00"; fontcolor="#8a5400";

    SCHED   [label="scheduler.Scheduler\nloop + backoff + signals", fillcolor="#ffffff", color="#c97a00"];
    RUN     [label="run.execute_plugin\nrun_ingestor + bookkeeping", fillcolor="#ffffff", color="#c97a00"];
    DISC    [label="discovery\ncarga dinámica\ndesde plugins/", fillcolor="#ffffff", color="#c97a00"];
    REG     [label="registry\ninstall/enable/disable", fillcolor="#ffffff", color="#c97a00"];
    STATE   [label="state\nSQLite local\n plugins · runs · pending", shape=cylinder, fillcolor="#ffffff", color="#c97a00"];
    PROTO   [label="LocalPlugin (Protocol)\nname/version/source_type\nbuild_source\nvalidate_requirements", fillcolor="#ffe4c8", color="#c97a00", style="rounded,filled,dashed"];
    CFG_L   [label="config\nbridge_url + token\n~/.memex-local/config.toml", fillcolor="#ffffff", color="#c97a00"];
    CLI_L   [label="cli  memex-local\ndaemon / plugin / status", fillcolor="#ffffff", color="#c97a00"];

    subgraph cluster_plugins {
      label="~/.memex-local/plugins/  (drop-in)";
      style="rounded,dashed"; color="#c97a00";
      PLUGIN_UNI [label="imap-university\n(wrapper de ImapSource)", fillcolor="#fffaf0", color="#c97a00"];
      PLUGIN_X   [label="...futuros plugins\n(slack, AW, etc.)", fillcolor="#fffaf0", color="#c97a00", style="rounded,filled,dashed"];
    }
  }

  // ---------------- memex API (VPS) ----------------
  subgraph cluster_api {
    label="memex API (FastAPI, en VPS)";
    style="rounded,filled"; fillcolor="#ecffe8"; color="#2f8f2f"; fontcolor="#1f6b1f";

    BRIDGE  [label="api/routers/bridge.py\nPOST /bridge/ingest\n(recibe del cliente local)", fillcolor="#ffffff", color="#2f8f2f", penwidth=2.0];
    INGEST  [label="api/routers/ingest.py\nPOST /ingest/batch\n(usado por imap-cli en VPS)", fillcolor="#ffffff", color="#2f8f2f"];
    SOURCES [label="api/routers/sources.py\nCRUD + ensure +\n /sources/{id}/checkpoint", fillcolor="#ffffff", color="#2f8f2f"];

    INSERT  [label="core.inbox.insert_record\nINSERT ON CONFLICT", fillcolor="#ffffff", color="#2f8f2f"];
    DB      [label="Postgres\n sources · inbox\n source_checkpoints", shape=cylinder, fillcolor="#ffffff", color="#2f8f2f"];
  }

  // ---------- relaciones de contrato ----------
  IMAP_SRC -> SRC   [label="implements", style=dashed, color="#7a4ddb"];
  HTTPC    -> SNK   [label="implements", style=dashed, color="#7a4ddb"];
  PLUGIN_UNI -> PROTO [label="implements", style=dashed, color="#c97a00"];
  PLUGIN_UNI -> IMAP_SRC [label="reusa", style=dashed, color="#7a4ddb"];

  // ---------- flujo cliente local ----------
  CLI_L  -> CFG_L   [label="carga"];
  CLI_L  -> SCHED   [label="daemon start"];
  CLI_L  -> REG     [label="install / enable"];
  CLI_L  -> DISC    [label="scan"];
  CLI_L  -> STATE   [label="status / runs"];

  SCHED  -> DISC    [label="scan plugins/"];
  SCHED  -> STATE   [label="enabled? schedule?"];
  SCHED  -> RUN     [label="dispatch"];

  RUN    -> PROTO   [label="build_source(cfg)"];
  RUN    -> STATE   [label="start_run / finalize"];
  RUN    -> RUNNER  [label="drives"];
  RUN    -> HTTPC   [label="ensure_source\nresolve source_id"];

  RUNNER -> SRC     [label="fetch"];
  RUNNER -> SNK     [label="post + checkpoint"];

  DISC   -> PLUGIN_UNI [label="importlib"];
  DISC   -> PLUGIN_X   [label="importlib", style=dotted];

  REG    -> STATE   [label="enable/disable"];

  // ---------- transporte HTTP cliente → VPS ----------
  HTTPC  -> BRIDGE   [label="POST /bridge/ingest\nBearer", color="#c97a00", penwidth=1.6];
  HTTPC  -> SOURCES  [label="ensure +\ncheckpoint", color="#c97a00"];

  // ---------- flujo VPS ----------
  BRIDGE -> INSERT  [label="por record"];
  INGEST -> INSERT  [label="por record"];
  INSERT -> DB;
  SOURCES -> DB;

  // ---------- ingestor IMAP del VPS (camino paralelo) ----------
  IMAP_CLI -> RUNNER  [label="drives", color="#2d6cdf"];
  IMAP_CLI -> HTTPC   [label="ingest_path=\n/ingest/batch", color="#2d6cdf"];

  // ---------- mundo externo ----------
  GMAIL [label="Gmail / Outlook / IMAP\nuniversitario detrás de\nfirewall que el VPS no\nalcanza", shape=cylinder, fillcolor="#fffaf0", color="#c97a00"];
  IMAP_SRC -> GMAIL [label="IMAPS"];
}
